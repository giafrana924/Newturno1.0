rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: notes
    // Document ID: {noteId}
    // Fields:
    //   - id: string (required) - Unique identifier
    //   - title: string (required) - Title of the note
    //   - content: string (required) - Markdown content
    //   - parentId: string (optional/nullable) - Parent note ID
    //   - order: number (required) - Display order
    //   - updatedAt: number (required) - Last update timestamp
    //   - tags: list (required) - Array of strings
    //   - uid: string (required) - Owner UID
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function isValidNote(data) {
      return data.keys().hasAll(['id', 'title', 'content', 'order', 'updatedAt', 'tags', 'uid']) &&
             data.id is string &&
             data.title is string && data.title.size() <= 500 &&
             data.content is string && data.content.size() <= 100000 &&
             data.order is number &&
             data.updatedAt is number &&
             data.tags is list &&
             data.uid is string && data.uid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /notes/{noteId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidNote(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidNote(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
